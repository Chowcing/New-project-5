# Vite dev server proxies /api to this backend origin.
VITE_API_BASE_URL=/api/v1

# AMap JS API key for offline place picker and autocomplete. Leave empty to keep manual input only.
VITE_AMAP_KEY=

# Optional. Fill this when the AMap key enables security code validation.
VITE_AMAP_SECURITY_JS_CODE=

# Optional. Limit autocomplete to a city, for example: 广州. Empty means nationwide search.
VITE_AMAP_CITY=
