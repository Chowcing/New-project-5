FROM node:22-alpine AS build
WORKDIR /app
COPY package*.json ./
RUN npm ci
COPY . .
ARG VITE_API_BASE_URL=/api/v1
ARG EXPENSE_DEPLOYMENT_VERSION=local-dev
ARG VITE_AMAP_KEY=
ARG VITE_AMAP_SECURITY_JS_CODE=
ARG VITE_AMAP_CITY=
ENV VITE_API_BASE_URL=$VITE_API_BASE_URL
ENV EXPENSE_DEPLOYMENT_VERSION=$EXPENSE_DEPLOYMENT_VERSION
ENV VITE_EXPENSE_DEPLOYMENT_VERSION=$EXPENSE_DEPLOYMENT_VERSION
ENV VITE_AMAP_KEY=$VITE_AMAP_KEY
ENV VITE_AMAP_SECURITY_JS_CODE=$VITE_AMAP_SECURITY_JS_CODE
ENV VITE_AMAP_CITY=$VITE_AMAP_CITY
RUN npm run build

FROM nginx:1.27-alpine
COPY --from=build /app/dist /usr/share/nginx/html
COPY nginx/default.conf /etc/nginx/conf.d/default.conf
EXPOSE 80
