# Copy this file to .env on the production host and fill every secret before starting docker-compose.prod.yml.

# MySQL root password. Use a long random value and store it in your password manager.
MYSQL_ROOT_PASSWORD=

# Application database credentials shared by backend and MySQL.
MYSQL_DATABASE=expense_tracker
MYSQL_USER=expense_app
MYSQL_PASSWORD=

# JWT secret for HS256 signing. Use at least 32 random ASCII characters.
JWT_SECRET=

# Optional token lifetimes.
JWT_ACCESS_MINUTES=30
JWT_REFRESH_DAYS=14

# Comma-separated existing usernames that can access the admin console.
ADMIN_USERNAMES=

# SMTP settings used for registration/login email verification codes.
MAIL_FROM=
MAIL_LOCAL_LOG_ENABLED=false
SPRING_MAIL_HOST=
SPRING_MAIL_PORT=587
SPRING_MAIL_USERNAME=
SPRING_MAIL_PASSWORD=
SPRING_MAIL_PROPERTIES_MAIL_SMTP_AUTH=true
SPRING_MAIL_PROPERTIES_MAIL_SMTP_STARTTLS_ENABLE=true

# Keep enabled so backend startup applies Flyway migrations.
FLYWAY_ENABLED=true
# Keep 0 for normal installs and existing project databases; change only for documented recovery.
FLYWAY_BASELINE_VERSION=0

# Application time zone used by backend scheduling, date defaults, and JVM timezone.
APP_TIME_ZONE=Asia/Shanghai

# Deployment version shown in the frontend and returned by backend responses.
# Leave empty only if the deployment command exports a git commit value before docker compose build/up.
EXPENSE_DEPLOYMENT_VERSION=

# Container path for transaction receipt images. docker-compose.prod.yml mounts ./uploads to /app/uploads.
TRANSACTION_IMAGE_DIR=/app/uploads/transaction-images
# Days to keep physical receipt image files after their database rows are soft-deleted.
TRANSACTION_IMAGE_RETENTION_DAYS=7

# OCR is disabled by default. Set OCR_ENABLED=true and OCR_PROVIDER=local to use the local PaddleOCR sidecar.
OCR_ENABLED=false
OCR_PROVIDER=disabled
LOCAL_OCR_BASE_URL=http://ocr-service:9000
# OCR sidecar build settings. The mirror and timeout reduce first-build failures on slow networks.
OCR_PYTHON_BASE_IMAGE=python:3.11-slim
OCR_PIP_INDEX_URL=https://pypi.tuna.tsinghua.edu.cn/simple
OCR_PIP_EXTRA_INDEX_URL=
OCR_PIP_DEFAULT_TIMEOUT=120

# Frontend build-time settings. Rebuild the frontend image after changing these values.
VITE_API_BASE_URL=/api/v1
VITE_AMAP_KEY=
VITE_AMAP_SECURITY_JS_CODE=
VITE_AMAP_CITY=
