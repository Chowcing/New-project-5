# MySQL root password used by docker-compose files.
MYSQL_ROOT_PASSWORD=change-me-root

# Application database credentials shared by backend and MySQL.
MYSQL_DATABASE=expense_tracker
MYSQL_USER=expense_app
MYSQL_PASSWORD=change-me-app

# JWT secret must be at least 32 bytes for HS256.
JWT_SECRET=please-change-this-dev-secret-32-bytes-min

# Comma-separated usernames that can access /admin after logging in.
ADMIN_USERNAMES=

# Enable backend database migrations on startup.
FLYWAY_ENABLED=true
FLYWAY_BASELINE_VERSION=0

# Application time zone used by backend scheduling, date defaults, and JVM timezone.
APP_TIME_ZONE=Asia/Shanghai

# Deployment version shown in the frontend and returned by backend responses.
EXPENSE_DEPLOYMENT_VERSION=local-dev

# Directory used by the backend to persist transaction receipt images.
TRANSACTION_IMAGE_DIR=uploads/transaction-images
TRANSACTION_IMAGE_RETENTION_DAYS=7

# OCR is disabled by default. Set OCR_ENABLED=true and OCR_PROVIDER=local to use the local PaddleOCR sidecar.
OCR_ENABLED=false
OCR_PROVIDER=disabled
LOCAL_OCR_BASE_URL=http://localhost:9000
# OCR sidecar build settings. The mirror and timeout reduce first-build failures on slow networks.
OCR_PYTHON_BASE_IMAGE=python:3.11-slim
OCR_PIP_INDEX_URL=https://pypi.tuna.tsinghua.edu.cn/simple
OCR_PIP_EXTRA_INDEX_URL=
OCR_PIP_DEFAULT_TIMEOUT=120
